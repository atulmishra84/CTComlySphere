  "scanning_configurations": {
    "timeout_seconds": 30,
    "max_concurrent_scans": 10,
    "retry_attempts": 3,
    "scan_frequency_hours": 24,
    "high_priority_protocols": ["kubernetes", "rest_api", "grpc"]
  },
  "compliance_mappings": {
