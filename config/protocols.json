    "HITRUST_CSF": {
      "critical_protocols": ["kubernetes", "docker", "grpc"],
      "required_security": ["access_control", "network_security", "data_protection"]
    },
    "FDA_SAMD": {
      "critical_protocols": ["grpc", "mqtt", "docker"],
      "required_security": ["validation", "traceability", "change_control"]
    },
    "GDPR": {
      "critical_protocols": ["rest_api", "websocket", "graphql"],
      "required_security": ["consent_management", "data_minimization", "encryption"]
    },
    "SOC2_TYPE_II": {
      "critical_protocols": ["kubernetes", "rest_api", "graphql"],
      "required_security": ["logical_access", "monitoring", "confidentiality"]
    }
