# CT ComplySphere Collector Agent — Environment Configuration
# ===========================================================
# Copy this file to .env and fill in your values.
# Used by both the Python agent and docker-compose.

# ── Required ──────────────────────────────────────────────────────────────────
PLATFORM_URL=https://your-complysphere-platform.example.com
API_TOKEN=paste-your-token-here

# ── Scan Settings ─────────────────────────────────────────────────────────────
# How often to scan (in seconds). Default: 3600 (1 hour)
SCAN_INTERVAL=3600

# Comma-separated list of scanners to enable.
# Available: docker, kubernetes, mcp_protocol, process, clawbot, cloud_service, model_registry
# Leave blank to enable all.
ENABLED_SCANNERS=docker,mcp_protocol,clawbot,process

# Comma-separated list of hostnames / IP CIDRs to probe.
# Leave blank to scan localhost only.
# Example: 10.0.0.0/24,192.168.1.10,my-k8s-api-server
SCAN_TARGETS=

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
