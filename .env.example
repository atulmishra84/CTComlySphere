# =============================================================================
# CT ComplySphere — Environment Variables
# Copy this file to .env and fill in the values before running locally or
# deploying. Never commit a populated .env file to version control.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by SQLAlchemy.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://complyadmin:changeme@localhost:5432/complysphere

# Random secret used by Flask to sign session cookies.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── Optional: AWS cloud scanning ──────────────────────────────────────────────

# AWS IAM access key with read-only permissions for cloud-asset scanning.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS IAM secret key paired with the access key above.
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Default AWS region for API calls when no region is specified.
AWS_DEFAULT_REGION=us-east-1

# ── Optional: Azure cloud scanning ───────────────────────────────────────────

# Azure Active Directory tenant (directory) ID for the service principal.
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID of the Azure service principal used for scanning.
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret of the Azure service principal used for scanning.
AZURE_CLIENT_SECRET=your-azure-client-secret-here

# Azure subscription ID to scan for AI resources.
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Optional: GCP cloud scanning ─────────────────────────────────────────────

# Full JSON content of a GCP service-account key file with read-only access.
# Paste the entire JSON as a single-line string (escape inner quotes as needed).
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"..."}
